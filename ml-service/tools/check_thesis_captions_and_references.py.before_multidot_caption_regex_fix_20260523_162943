#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import re
from datetime import datetime
from pathlib import Path

from docx import Document


TABLE_CAPTION_RE = re.compile(r"^\s*Tablo\s+\d+(\.\d+|\.x)?[\.:]?\s+", re.IGNORECASE)
FIGURE_CAPTION_RE = re.compile(r"^\s*Şekil\s+\d+(\.\d+|\.x)?[\.:]?\s+", re.IGNORECASE)
TECH_REFERENCE_MARKER_RE = re.compile(r"\[(BIB|LR|MAN)\d{3}\]")
APA_REFERENCE_RE = re.compile(r"^[A-ZÇĞİÖŞÜ][^\n]{2,220}\((?:19|20)\d{2}\)\.")
APA_INLINE_CITATION_RE = re.compile(r"\([^()]*?,\s*(?:19|20)\d{2}[^()]*?\)")


def clean(value) -> str:
    if value is None:
        return ""
    return str(value).strip()


def status(ok: bool) -> str:
    return "ok" if ok else "check"


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Check thesis table/figure captions and reference signals."
    )
    parser.add_argument(
        "--docx",
        default="docs/tez_ana_taslak_tr_guncel_sau_fbe.docx",
    )
    parser.add_argument(
        "--output-md",
        default="docs/tez_caption_reference_check_report_sau_fbe_frontmatter.md",
    )
    parser.add_argument(
        "--output-json",
        default="docs/tez_caption_reference_check_report_sau_fbe_frontmatter.json",
    )
    args = parser.parse_args()

    docx_path = Path(args.docx)
    if not docx_path.exists():
        raise SystemExit(f"[ERROR] DOCX not found: {docx_path}")

    doc = Document(docx_path)
    paragraphs = [(i, p.text.strip()) for i, p in enumerate(doc.paragraphs, start=1)]

    table_captions = []
    figure_captions = []
    tech_reference_hits = []
    inline_apa_hits = []
    apa_reference_like = []
    kaynakca_heading_found = False
    kaynakca_seen = False

    for i, text in paragraphs:
        if not text:
            continue

        if TABLE_CAPTION_RE.search(text):
            table_captions.append({"paragraph": i, "text": text})

        if FIGURE_CAPTION_RE.search(text):
            figure_captions.append({"paragraph": i, "text": text})

        if TECH_REFERENCE_MARKER_RE.search(text):
            tech_reference_hits.append({"paragraph": i, "text": text})

        if APA_INLINE_CITATION_RE.search(text):
            inline_apa_hits.append({"paragraph": i, "text": text})

        if text.lower() in {"kaynakça", "kaynaklar", "references", "bibliography"}:
            kaynakca_heading_found = True
            kaynakca_seen = True
            continue

        if kaynakca_seen and APA_REFERENCE_RE.search(text):
            apa_reference_like.append({"paragraph": i, "text": text})

    table_count = len(doc.tables)
    shape_count = len(doc.inline_shapes)
    table_caption_count = len(table_captions)
    figure_caption_count = len(figure_captions)
    tech_reference_marker_count = len(tech_reference_hits)
    apa_inline_citation_count = len(inline_apa_hits)
    apa_reference_like_count = len(apa_reference_like)

    reference_signal_ok = (
        tech_reference_marker_count >= 1
        or apa_inline_citation_count >= 1
        or apa_reference_like_count >= 1
    )

    checks = [
        {
            "check": "Word table object count",
            "expected": ">= 1",
            "actual": table_count,
            "status": status(table_count >= 1),
        },
        {
            "check": "Word inline shape count",
            "expected": ">= 1",
            "actual": shape_count,
            "status": status(shape_count >= 1),
        },
        {
            "check": "Detected table caption count",
            "expected": f">= table count or manually justified; table_count={table_count}",
            "actual": table_caption_count,
            "status": status(table_caption_count >= table_count or table_caption_count >= 1),
        },
        {
            "check": "Detected figure caption count",
            "expected": f">= inline shape count or manually justified; shape_count={shape_count}",
            "actual": figure_caption_count,
            "status": status(figure_caption_count >= shape_count or figure_caption_count >= 1),
        },
        {
            "check": "Reference signal count",
            "expected": ">= 1 technical marker, APA inline citation, or APA-like bibliography entry",
            "actual": (
                f"technical_markers={tech_reference_marker_count}; "
                f"apa_inline={apa_inline_citation_count}; "
                f"apa_reference_like={apa_reference_like_count}"
            ),
            "status": status(reference_signal_ok),
        },
        {
            "check": "Kaynakça heading",
            "expected": "present",
            "actual": "present" if kaynakca_heading_found else "missing",
            "status": status(kaynakca_heading_found),
        },
    ]

    ok_count = sum(1 for c in checks if c["status"] == "ok")
    check_count = sum(1 for c in checks if c["status"] != "ok")

    summary = {
        "generated_at_utc": datetime.utcnow().isoformat(),
        "docx": str(docx_path),
        "ok": ok_count,
        "check": check_count,
        "total": len(checks),
        "word_table_count": table_count,
        "inline_shape_count": shape_count,
        "detected_table_caption_count": table_caption_count,
        "detected_figure_caption_count": figure_caption_count,
        "technical_reference_marker_count": tech_reference_marker_count,
        "apa_inline_citation_count": apa_inline_citation_count,
        "apa_reference_like_count": apa_reference_like_count,
        "kaynakca_heading_found": kaynakca_heading_found,
        "checks": checks,
        "table_caption_examples": table_captions[:30],
        "figure_caption_examples": figure_captions[:30],
        "technical_reference_examples": tech_reference_hits[:30],
        "apa_inline_examples": inline_apa_hits[:30],
        "apa_reference_like_examples": apa_reference_like[:30],
    }

    output_json = Path(args.output_json)
    output_json.parent.mkdir(parents=True, exist_ok=True)
    output_json.write_text(json.dumps(summary, indent=2, ensure_ascii=False), encoding="utf-8")

    md = []
    md.append("# Tez Tablo/Şekil Başlığı ve Kaynakça Ön Kontrol Raporu")
    md.append("")
    md.append(f"- Generated at UTC: `{summary['generated_at_utc']}`")
    md.append(f"- DOCX: `{summary['docx']}`")
    md.append("")
    md.append("## 1. Özet")
    md.append("")
    md.append(f"- OK: `{ok_count}`")
    md.append(f"- Check: `{check_count}`")
    md.append(f"- Total: `{len(checks)}`")
    md.append(f"- Word table count: `{table_count}`")
    md.append(f"- Inline shape count: `{shape_count}`")
    md.append(f"- Detected table captions: `{table_caption_count}`")
    md.append(f"- Detected figure captions: `{figure_caption_count}`")
    md.append(f"- Technical reference marker count: `{tech_reference_marker_count}`")
    md.append(f"- APA inline citation count: `{apa_inline_citation_count}`")
    md.append(f"- APA reference-like count: `{apa_reference_like_count}`")
    md.append("")
    md.append("## 2. Kontroller")
    md.append("")
    md.append("| Kontrol | Beklenen | Mevcut | Durum |")
    md.append("|---|---|---:|---|")
    for c in checks:
        actual = str(c["actual"]).replace("|", "\\|")
        md.append(f"| {c['check']} | {c['expected']} | {actual} | {c['status']} |")

    md.append("")
    md.append("## 3. Bulunan Tablo Başlığı Örnekleri")
    md.append("")
    if table_captions:
        for item in table_captions[:20]:
            md.append(f"- P{item['paragraph']}: {item['text']}")
    else:
        md.append("Tablo başlığı bulunamadı.")

    md.append("")
    md.append("## 4. Bulunan Şekil Başlığı Örnekleri")
    md.append("")
    if figure_captions:
        for item in figure_captions[:20]:
            md.append(f"- P{item['paragraph']}: {item['text']}")
    else:
        md.append("Şekil başlığı bulunamadı.")

    md.append("")
    md.append("## 5. Kaynakça / Referans Sinyalleri")
    md.append("")
    md.append(f"- Teknik marker sayısı: `{tech_reference_marker_count}`")
    md.append(f"- APA metin içi atıf sinyali sayısı: `{apa_inline_citation_count}`")
    md.append(f"- Kaynakça bölümündeki APA-benzeri kaynak satırı sayısı: `{apa_reference_like_count}`")
    md.append("")
    if apa_reference_like:
        md.append("### APA-benzeri kaynakça satırı örnekleri")
        md.append("")
        for item in apa_reference_like[:20]:
            md.append(f"- P{item['paragraph']}: {item['text'][:350]}")
    elif tech_reference_hits:
        md.append("### Teknik marker örnekleri")
        md.append("")
        for item in tech_reference_hits[:20]:
            md.append(f"- P{item['paragraph']}: {item['text'][:350]}")
    else:
        md.append("Referans sinyali bulunamadı.")

    md.append("")
    md.append("## 6. Not")
    md.append("")
    md.append(
        "Bu rapor ön kontroldür. Teknik `[BIB/LR/MAN]` marker’ları temizlendikten sonra "
        "referans kontrolü APA-benzeri metin içi atıflar ve Kaynakça bölümündeki APA-benzeri "
        "kaynakça satırları üzerinden yapılmaktadır. Nihai APA7 biçimi ayrıca manuel kontrol edilmelidir."
    )

    output_md = Path(args.output_md)
    output_md.parent.mkdir(parents=True, exist_ok=True)
    output_md.write_text("\n".join(md), encoding="utf-8")

    print("[INFO] MD:", output_md)
    print("[INFO] JSON:", output_json)
    print("[INFO] Summary:", {"ok": ok_count, "check": check_count, "total": len(checks)})


if __name__ == "__main__":
    main()
